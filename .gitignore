# -------------------------------------------------------------------------
# Rust Specific
# -------------------------------------------------------------------------

# Cargo build directory (Contains all binaries, tests, and dependencies)
pkg/agent/rust-proxy/target/
pkg/agent/rust-proxy/bin

# Backup files generated by rustfmt
**/*.rs.bk

yaml.test

# Cargo.lock (Uncomment below to ignore if this is a Rust *library* crate. 
# Keep it commented out if this is a binary/application crate).
# Cargo.lock

# Rust coverage tool outputs (e.g., cargo-tarpaulin, grcov)
*.profraw
*.profdata
tarpaulin-report.html
cobertura.xml
coverage/

# -------------------------------------------------------------------------
# OS Binaries (If moved manually outside of /target/)
# -------------------------------------------------------------------------
*.exe
*.exe~
*.dll
*.so
*.dylib

# Ignore the server binary output but not any folders with the name server
/server
!/server/

# -------------------------------------------------------------------------
# Keploy Specific & Project Configs
# -------------------------------------------------------------------------
keploy-config.yaml
keploy.yml
keploy-logs.txt
keploy

# -------------------------------------------------------------------------
# Web, UI, and Scripts
# -------------------------------------------------------------------------
web/public/*
!web/public/README.md
!web/public/index.html
ui
.deploy.sh
.env

# -------------------------------------------------------------------------
# Test Data & Reports
# -------------------------------------------------------------------------
test-reports/
testdata/

# -------------------------------------------------------------------------
# IDEs and OS generated files
# -------------------------------------------------------------------------
.idea/
.vscode/

.DS_Store
._.DS_Store
**/.DS_Store
**/._.DS_Store

# -------------------------------------------------------------------------
# Misc
# -------------------------------------------------------------------------
# Ignore zip files
*.zip

# Ignore C and header files (e.g., if using Rust FFI)
*.c
*.h